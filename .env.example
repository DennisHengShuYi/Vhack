# Cloud providers (at least one required for CLOUD mode)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Edge LLM (Ollama — optional, enables offline mode)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Override provider selection (AUTO / CLOUD / EDGE / RULES)
# ACTIVE_PROVIDER=AUTO

# Override model name
LLM_MODEL=gpt-4o-mini


